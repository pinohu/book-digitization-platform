# Book Digitization Platform — Environment Variables
# Copy this file: cp .env.example .env.local
# Then fill in each value from the service dashboards listed below.
# NEVER commit .env.local to git.

# ─── Authentication (Clerk) ─────────────────────────────────────────────
# Dashboard: https://dashboard.clerk.com → Create application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/en/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/en/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/en/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/en/dashboard

# ─── Payments (Stripe) ──────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Webhook: https://dashboard.stripe.com/webhooks → Add endpoint → your-domain/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
BILLING_PLAN_ENV=test

# ─── Database (Neon Postgres) ───────────────────────────────────────────
# Dashboard: https://console.neon.tech → Project → Connection Details
# Use the pooled connection string (ending in -pooler.neon.tech)
DATABASE_URL=postgresql://user:pass@host-pooler.neon.tech/dbname?sslmode=require

# ─── App Configuration ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://book-digitization-platform.vercel.app
NODE_ENV=production

# ─── Monitoring (Optional) ──────────────────────────────────────────────
# Sentry: https://sentry.io → Create Project → Client Keys
# SENTRY_DSN=https://...@sentry.io/...
# PostHog: https://app.posthog.com → Project Settings → Project API Key
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
